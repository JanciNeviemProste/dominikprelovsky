# --- Resend (transakčný email) ---
# Vytvor účet na https://resend.com a vygeneruj API key.
RESEND_API_KEY=
# Doména musí byť verifikovaná v Resend (DNS DKIM/SPF/DMARC).
# Kým nie je, ponechaj fallback na noreply@dominikprelovsky.sk a Resend pošle z onboarding@resend.dev.
RESEND_FROM_EMAIL="Dominik Prelovský <noreply@dominikprelovsky.sk>"
COACH_EMAIL=info@dominikprelovsky.sk

# --- Sanity CMS (správa obsahu klientom) ---
# Po vytvorení projektu na https://sanity.io vyplň project ID a dataset.
# Bez týchto premenných web beží len so vstavaným fallback obsahom z lib/content/.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=
# Heslo pre webhook /api/sanity-webhook — pošli si do Sanity webhook nastavení.
SANITY_WEBHOOK_SECRET=

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://dominikprelovsky.sk
